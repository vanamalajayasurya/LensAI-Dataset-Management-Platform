
import React, { useState, useEffect } from "react";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Search, ShoppingCart, Book, ExternalLink, X, TrendingUp, Package, Loader2, Sparkles } from "lucide-react";
import { motion, AnimatePresence } from "framer-motion";
import { base44 } from "@/api/base44Client";

export default function RelatedLinksPanel({ object, onClose, imageUrl }) {
  const { label, confidence, attributes, bbox } = object;
  const [similarProducts, setSimilarProducts] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  const [activeTab, setActiveTab] = useState('links');

  useEffect(() => {
    if (label) {
      findSimilarProducts();
    }
  }, [label]);

  const findSimilarProducts = async () => {
    setLoading(true);
    setError(null);
    try {
      // FIXED: Use text-only search without image to avoid rate limits
      const searchPrompt = `Find visually similar ${label} products available for purchase online in India.

Search for products that match this description and provide detailed information about each one.

For each product, include:
- product_name: Full product name
- match_type: "exact" or "similar"
- brand: Brand name (if known)
- color: Primary color (if known)
- price_range: Approximate price in INR
- source: Where to buy (Amazon India, Flipkart, etc.)
- product_url: Shopping link (can be generic like amazon.in search)
- image_url: Product image URL (if available)
- key_features: 2-3 main features

Find 5-8 products prioritizing exact brand/model matches first, then similar alternatives.

Return valid JSON:
{
  "products": [
    {
      "product_name": "Example Product Name",
      "match_type": "exact",
      "brand": "Brand Name",
      "color": "color",
      "price_range": "₹1,000 - ₹2,000",
      "source": "Amazon India",
      "product_url": "https://amazon.in/s?k=...",
      "image_url": "https://...",
      "key_features": ["feature 1", "feature 2"]
    }
  ]
}`;

      const result = await base44.integrations.Core.InvokeLLM({
        prompt: searchPrompt,
        add_context_from_internet: true,
        response_json_schema: {
          type: "object",
          properties: {
            products: {
              type: "array",
              items: {
                type: "object",
                properties: {
                  product_name: { type: "string" },
                  match_type: { type: "string" },
                  brand: { type: "string" },
                  color: { type: "string" },
                  price_range: { type: "string" },
                  source: { type: "string" },
                  product_url: { type: "string" },
                  image_url: { type: "string" },
                  key_features: { type: "array", items: { type: "string" } }
                }
              }
            }
          }
        }
      });

      // Sort: exact matches first
      const sorted = (result.products || []).sort((a, b) => {
        if (a.match_type === 'exact' && b.match_type !== 'exact') return -1;
        if (a.match_type !== 'exact' && b.match_type === 'exact') return 1;
        return 0;
      });

      setSimilarProducts(sorted);
    } catch (error) {
      console.error('Error finding similar products:', error);
      setError('Unable to find products. The AI service is temporarily unavailable. Please use the Quick Links below.');
      // Auto-switch to Quick Links tab on error
      setActiveTab('links');
    }
    setLoading(false);
  };

  const generateLinks = (query) => {
    const encodedQuery = encodeURIComponent(query);
    return {
      google: `https://www.google.com/search?q=${encodedQuery}`,
      amazon: `https://www.amazon.in/s?k=${encodedQuery}`,
      wikipedia: `https://en.wikipedia.org/wiki/${encodedQuery.replace(/ /g, '_')}`,
      images: `https://www.google.com/search?q=${encodedQuery}&tbm=isch`,
      shopping: `https://www.google.com/search?q=${encodedQuery}&tbm=shop`,
      youtube: `https://www.youtube.com/results?search_query=${encodedQuery}`
    };
  };

  const links = generateLinks(label);

  const linkItems = [
    {
      name: "Google Search",
      icon: Search,
      url: links.google,
      color: "from-blue-500 to-blue-600",
      description: "Search the web"
    },
    {
      name: "Image Search",
      icon: TrendingUp,
      url: links.images,
      color: "from-green-500 to-emerald-600",
      description: "Find similar images"
    },
    {
      name: "Amazon",
      icon: ShoppingCart,
      url: links.amazon,
      color: "from-orange-500 to-amber-600",
      description: "Shop online"
    },
    {
      name: "Shopping",
      icon: Package,
      url: links.shopping,
      color: "from-purple-500 to-pink-600",
      description: "Compare prices"
    },
    {
      name: "Wikipedia",
      icon: Book,
      url: links.wikipedia,
      color: "from-gray-600 to-gray-700",
      description: "Learn more"
    },
    {
      name: "YouTube",
      icon: ExternalLink,
      url: links.youtube,
      color: "from-red-500 to-red-600",
      description: "Watch videos"
    }
  ];

  return (
    <motion.div
      initial={{ opacity: 0, x: 20 }}
      animate={{ opacity: 1, x: 0 }}
      exit={{ opacity: 0, x: 20 }}
      className="sticky top-4"
    >
      <Card className="border-none shadow-2xl overflow-hidden">
        <CardHeader className="bg-gradient-to-r from-purple-600 to-blue-600 text-white pb-4">
          <div className="flex items-start justify-between">
            <div className="flex-1">
              <CardTitle className="text-2xl font-bold mb-2 capitalize">
                {label}
              </CardTitle>
              {confidence && (
                <Badge className="bg-white/20 text-white border-white/30">
                  {Math.round(confidence * 100)}% confidence
                </Badge>
              )}
            </div>
            <Button
              variant="ghost"
              size="icon"
              onClick={onClose}
              className="text-white hover:bg-white/20"
            >
              <X className="w-5 h-5" />
            </Button>
          </div>
        </CardHeader>

        <CardContent className="p-0">
          {/* Tabs */}
          <div className="flex border-b">
            <button
              onClick={() => setActiveTab('products')}
              className={`flex-1 px-4 py-3 text-sm font-medium transition-colors ${
                activeTab === 'products'
                  ? 'border-b-2 border-purple-600 text-purple-600 bg-purple-50'
                  : 'text-gray-600 hover:bg-gray-50'
              }`}
            >
              <Sparkles className="w-4 h-4 inline mr-2" />
              Similar Products
            </button>
            <button
              onClick={() => setActiveTab('links')}
              className={`flex-1 px-4 py-3 text-sm font-medium transition-colors ${
                activeTab === 'links'
                  ? 'border-b-2 border-purple-600 text-purple-600 bg-purple-50'
                  : 'text-gray-600 hover:bg-gray-50'
              }`}
            >
              <ExternalLink className="w-4 h-4 inline mr-2" />
              Quick Links
            </button>
          </div>

          <div className="p-6 max-h-[600px] overflow-y-auto">
            <AnimatePresence mode="wait">
              {activeTab === 'products' ? (
                <motion.div
                  key="products"
                  initial={{ opacity: 0, y: 10 }}
                  animate={{ opacity: 1, y: 0 }}
                  exit={{ opacity: 0, y: -10 }}
                >
                  {error && (
                    <div className="mb-4 p-4 bg-orange-50 border border-orange-200 rounded-lg">
                      <p className="text-sm text-orange-800">{error}</p>
                    </div>
                  )}
                  
                  {loading ? (
                    <div className="flex flex-col items-center justify-center py-12">
                      <Loader2 className="w-8 h-8 text-purple-600 animate-spin mb-3" />
                      <p className="text-sm text-gray-600">Finding similar products...</p>
                      <p className="text-xs text-gray-500 mt-2">This may take a few seconds</p>
                    </div>
                  ) : similarProducts.length > 0 ? (
                    <div className="space-y-4">
                      {similarProducts.map((product, index) => (
                        <motion.a
                          key={index}
                          href={product.product_url}
                          target="_blank"
                          rel="noopener noreferrer"
                          initial={{ opacity: 0, y: 20 }}
                          animate={{ opacity: 1, y: 0 }}
                          transition={{ delay: index * 0.05 }}
                          className="block group"
                        >
                          <div className="border rounded-xl overflow-hidden hover:shadow-lg transition-all duration-200 bg-white">
                            {product.image_url && (
                              <div className="relative h-40 bg-gray-100 overflow-hidden">
                                <img
                                  src={product.image_url}
                                  alt={product.product_name}
                                  className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                  onError={(e) => {
                                    e.target.style.display = 'none';
                                  }}
                                />
                                {product.match_type === 'exact' && (
                                  <Badge className="absolute top-2 left-2 bg-green-500 text-white">
                                    Exact Match
                                  </Badge>
                                )}
                              </div>
                            )}
                            <div className="p-4">
                              <h4 className="font-semibold text-gray-900 mb-1 line-clamp-2 group-hover:text-purple-600 transition-colors">
                                {product.product_name}
                              </h4>
                              <div className="flex flex-wrap gap-2 mb-2">
                                {product.brand && (
                                  <Badge variant="outline" className="text-xs">
                                    {product.brand}
                                  </Badge>
                                )}
                                {product.color && (
                                  <Badge variant="outline" className="text-xs">
                                    {product.color}
                                  </Badge>
                                )}
                              </div>
                              {product.price_range && (
                                <p className="text-sm font-semibold text-green-600 mb-2">
                                  {product.price_range}
                                </p>
                              )}
                              {product.key_features && product.key_features.length > 0 && (
                                <div className="text-xs text-gray-600 mb-2">
                                  {product.key_features.slice(0, 2).map((feature, i) => (
                                    <span key={i} className="block">• {feature}</span>
                                  ))}
                                </div>
                              )}
                              <div className="flex items-center justify-between">
                                <span className="text-xs text-gray-500">{product.source}</span>
                                <ExternalLink className="w-4 h-4 text-gray-400 group-hover:text-purple-600 transition-colors" />
                              </div>
                            </div>
                          </div>
                        </motion.a>
                      ))}
                    </div>
                  ) : !error ? ( // Only show "No products found" if there's no general error
                    <div className="text-center py-12">
                      <Package className="w-12 h-12 mx-auto mb-3 text-gray-300" />
                      <p className="text-gray-600 mb-2">No similar products found</p>
                      <p className="text-sm text-gray-500 mb-4">Try the Quick Links tab to search manually</p>
                      <Button
                        variant="outline"
                        size="sm"
                        onClick={() => setActiveTab('links')}
                      >
                        View Quick Links
                      </Button>
                    </div>
                  ) : null} {/* If there's an error, don't show the "No products found" message either */}
                </motion.div>
              ) : (
                <motion.div
                  key="links"
                  initial={{ opacity: 0, y: 10 }}
                  animate={{ opacity: 1, y: 0 }}
                  exit={{ opacity: 0, y: -10 }}
                  className="space-y-3"
                >
                  {linkItems.map((item, index) => (
                    <motion.a
                      key={item.name}
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      initial={{ opacity: 0, y: 10 }}
                      animate={{ opacity: 1, y: 0 }}
                      transition={{ delay: index * 0.05 }}
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                      className="block"
                    >
                      <div className="flex items-center gap-3 p-3 rounded-xl border border-gray-200 hover:border-purple-300 hover:shadow-md transition-all duration-200 bg-white hover:bg-gradient-to-r hover:from-purple-50 hover:to-blue-50 group">
                        <div className={`w-10 h-10 rounded-lg bg-gradient-to-br ${item.color} flex items-center justify-center flex-shrink-0 shadow-sm group-hover:shadow-md transition-shadow`}>
                          <item.icon className="w-5 h-5 text-white" />
                        </div>
                        <div className="flex-1 min-w-0">
                          <p className="font-semibold text-gray-900 group-hover:text-purple-700 transition-colors">
                            {item.name}
                          </p>
                          <p className="text-xs text-gray-500">{item.description}</p>
                        </div>
                        <ExternalLink className="w-4 h-4 text-gray-400 group-hover:text-purple-600 transition-colors flex-shrink-0" />
                      </div>
                    </motion.a>
                  ))}
                </motion.div>
              )}
            </AnimatePresence>
          </div>

          {attributes && Object.keys(attributes).length > 0 && (
            <div className="border-t p-6 bg-gray-50">
              <h4 className="text-sm font-semibold text-gray-700 mb-3">Additional Details</h4>
              <div className="space-y-2">
                {Object.entries(attributes).map(([key, value]) => (
                  <div key={key} className="flex justify-between text-sm">
                    <span className="text-gray-600 capitalize">{key}:</span>
                    <span className="font-medium text-gray-900">{value}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </CardContent>
      </Card>
    </motion.div>
  );
}
