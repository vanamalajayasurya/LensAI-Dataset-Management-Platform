import React, { useState, useEffect } from "react";
import { base44 } from "@/api/base44Client";
import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Badge } from "@/components/ui/badge";
import { Skeleton } from "@/components/ui/skeleton";
import { ArrowLeft, Sparkles, FileText, Tag, MessageSquare, Languages, Loader2 } from "lucide-react";
import { Link } from "react-router-dom";
import { createPageUrl } from "@/utils";

import AnalysisSection from "../components/analysis/AnalysisSection";
import QuestionInput from "../components/analysis/QuestionInput";
import ObjectDetectionViewer from "../components/detection/ObjectDetectionViewer";

export default function AnalysisPage() {
  const urlParams = new URLSearchParams(window.location.search);
  const imageId = urlParams.get("id");
  const queryClient = useQueryClient();

  const [question, setQuestion] = useState("");
  const [isAnalyzing, setIsAnalyzing] = useState(false);

  const { data: image, isLoading } = useQuery({
    queryKey: ['image', imageId],
    queryFn: async () => {
      const images = await base44.entities.Image.filter({ id: imageId });
      return images[0];
    },
    enabled: !!imageId,
  });

  const updateImageMutation = useMutation({
    mutationFn: ({ id, data }) => base44.entities.Image.update(id, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['image', imageId] });
    },
  });

  useEffect(() => {
    if (image && !image.caption && !isAnalyzing) {
      performAnalysis();
    }
  }, [image]);

  const performAnalysis = async () => {
    if (!image) return;
    setIsAnalyzing(true);

    try {
      // IMPROVED PROMPT FOR BETTER OBJECT DETECTION WITH PROPER COORDINATES
      const analysisPrompt = `Analyze this image in detail. You MUST return a valid JSON with this exact structure:

{
  "caption": "A detailed 2-3 sentence description of what you see in the image",
  "objects": [
    {
      "label": "specific object name (e.g., laptop, mouse, keyboard, monitor, cup, book, phone)",
      "confidence": 0.95,
      "bbox": [x_min, y_min, x_max, y_max]
    }
  ],
  "text": "any visible text you can read, or empty string if none",
  "tags": ["tag1", "tag2", "tag3"]
}

CRITICAL INSTRUCTIONS FOR BOUNDING BOXES:
- Use absolute pixel coordinates in [x_min, y_min, x_max, y_max] format
- x_min, y_min = top-left corner coordinates
- x_max, y_max = bottom-right corner coordinates
- For a 640x480 image, valid coordinates are 0-640 for x and 0-480 for y
- Detect ALL visible objects - aim for at least 5-10 objects
- Include furniture, electronics, food items, accessories, text areas, etc.
- Be precise with coordinates - measure carefully where each object starts and ends
- Confidence should be 0.8-0.99 based on clarity

Example for a laptop in top-left quadrant of a 1920x1080 image:
{"label": "laptop", "confidence": 0.95, "bbox": [100, 150, 800, 650]}

Now analyze the provided image and return ONLY valid JSON.`;

      const result = await base44.integrations.Core.InvokeLLM({
        prompt: analysisPrompt,
        file_urls: [image.file_url],
        response_json_schema: {
          type: "object",
          properties: {
            caption: { type: "string" },
            objects: { 
              type: "array", 
              items: { 
                type: "object",
                properties: {
                  label: { type: "string" },
                  confidence: { type: "number" },
                  bbox: { 
                    type: "array", 
                    items: { type: "number" },
                    minItems: 4,
                    maxItems: 4
                  }
                },
                required: ["label", "bbox"]
              }
            },
            text: { type: "string" },
            tags: { type: "array", items: { type: "string" } }
          },
          required: ["caption", "objects", "text", "tags"]
        }
      });

      // Validate and filter objects
      const validObjects = (result.objects || []).filter(obj => {
        if (!obj.bbox || obj.bbox.length !== 4) {
          console.warn('Invalid bbox format:', obj);
          return false;
        }
        
        // Check if coordinates are reasonable (not negative, not ridiculously large)
        const allPositive = obj.bbox.every(coord => coord >= 0);
        // A generous upper bound for image dimensions, assuming no images larger than 10000x10000 pixels.
        // This is a sanity check, actual image dimensions might be needed for precise validation.
        const notTooLarge = obj.bbox.every(coord => coord < 10000); 
        
        if (!allPositive || !notTooLarge) {
          console.warn('Invalid bbox coordinates:', obj.bbox);
          return false;
        }
        
        return true;
      });

      await updateImageMutation.mutateAsync({
        id: image.id,
        data: {
          caption: result.caption,
          objects_detected: validObjects,
          ocr_text: result.text,
          tags: result.tags,
          visual_qa: []
        }
      });
    } catch (error) {
      console.error("Analysis error:", error);
    }

    setIsAnalyzing(false);
  };

  const handleAskQuestion = async () => {
    if (!question.trim() || !image) return;

    const currentQuestion = question;
    setQuestion("");

    try {
      const answer = await base44.integrations.Core.InvokeLLM({
        prompt: `Answer this question about the image: ${currentQuestion}`,
        file_urls: [image.file_url]
      });

      const newQA = {
        question: currentQuestion,
        answer
      };

      await updateImageMutation.mutateAsync({
        id: image.id,
        data: {
          visual_qa: [...(image.visual_qa || []), newQA]
        }
      });
    } catch (error) {
      console.error("Q&A error:", error);
    }
  };

  const translateText = async () => {
    if (!image?.ocr_text) return;

    try {
      const translation = await base44.integrations.Core.InvokeLLM({
        prompt: `Translate this text to English: ${image.ocr_text}`
      });

      await updateImageMutation.mutateAsync({
        id: image.id,
        data: { translation }
      });
    } catch (error) {
      console.error("Translation error:", error);
    }
  };

  if (isLoading) {
    return (
      <div className="min-h-screen p-4 md:p-8">
        <div className="max-w-5xl mx-auto space-y-6">
          <Skeleton className="h-96 w-full rounded-2xl" />
          <Skeleton className="h-32 w-full rounded-xl" />
        </div>
      </div>
    );
  }

  if (!image) {
    return (
      <div className="min-h-screen p-8 flex items-center justify-center">
        <Card className="p-8 text-center">
          <p className="text-gray-600">Image not found</p>
          <Link to={createPageUrl("Camera")}>
            <Button className="mt-4">Go to Camera</Button>
          </Link>
        </Card>
      </div>
    );
  }

  // Check if we have object detection data
  const hasObjectDetection = image.objects_detected && Array.isArray(image.objects_detected) && image.objects_detected.length > 0;

  return (
    <div className="min-h-screen p-4 md:p-8">
      <div className="max-w-7xl mx-auto">
        <Link to={createPageUrl("Gallery")}>
          <Button variant="ghost" className="mb-6 hover:bg-purple-50">
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back to Gallery
          </Button>
        </Link>

        {isAnalyzing ? (
          <Card className="p-8 border-none shadow-xl">
            <div className="flex flex-col items-center gap-4">
              <Loader2 className="w-12 h-12 text-purple-600 animate-spin" />
              <p className="text-gray-600">Analyzing image with AI...</p>
            </div>
          </Card>
        ) : (
          <div className="space-y-6">
            {/* Object Detection Viewer - Full Width */}
            {hasObjectDetection && (
              <ObjectDetectionViewer
                imageUrl={image.file_url}
                detectedObjects={image.objects_detected}
              />
            )}

            {/* Regular Image Display (if no object detection) */}
            {!hasObjectDetection && (
              <div className="grid lg:grid-cols-2 gap-6">
                <Card className="overflow-hidden border-none shadow-2xl">
                  <img 
                    src={image.file_url} 
                    alt="Analyzed" 
                    className="w-full h-full object-cover"
                  />
                </Card>

                <div className="space-y-4">
                  <AnalysisSection
                    icon={Sparkles}
                    title="AI Description"
                    content={image.caption}
                    bgGradient="from-purple-500 to-blue-600"
                  />

                  {image.tags && image.tags.length > 0 && (
                    <Card className="border-none shadow-xl p-4">
                      <div className="flex flex-wrap gap-2">
                        {image.tags.map((tag, i) => (
                          <Badge key={i} className="bg-purple-100 text-purple-800">
                            #{tag}
                          </Badge>
                        ))}
                      </div>
                    </Card>
                  )}
                </div>
              </div>
            )}

            {/* Additional Analysis Results */}
            <div className="grid lg:grid-cols-2 gap-6">
              {image.caption && hasObjectDetection && (
                <AnalysisSection
                  icon={Sparkles}
                  title="AI Description"
                  content={image.caption}
                  bgGradient="from-purple-500 to-blue-600"
                />
              )}

              {image.ocr_text && (
                <Card className="border-none shadow-xl">
                  <CardHeader className="pb-3">
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-2">
                        <div className="w-8 h-8 bg-gradient-to-br from-green-500 to-emerald-600 rounded-lg flex items-center justify-center">
                          <FileText className="w-4 h-4 text-white" />
                        </div>
                        <CardTitle className="text-lg">Extracted Text</CardTitle>
                      </div>
                      <Button 
                        size="sm" 
                        variant="outline"
                        onClick={translateText}
                        className="gap-2"
                      >
                        <Languages className="w-4 h-4" />
                        Translate
                      </Button>
                    </div>
                  </CardHeader>
                  <CardContent>
                    <p className="text-gray-700 whitespace-pre-wrap">{image.ocr_text}</p>
                    {image.translation && (
                      <div className="mt-4 pt-4 border-t">
                        <p className="text-sm text-gray-500 mb-1">Translation:</p>
                        <p className="text-gray-700">{image.translation}</p>
                      </div>
                    )}
                  </CardContent>
                </Card>
              )}
            </div>

            {/* Visual Q&A Section */}
            <div className="space-y-4">
              <QuestionInput
                question={question}
                setQuestion={setQuestion}
                onAsk={handleAskQuestion}
              />

              {image.visual_qa && image.visual_qa.length > 0 && (
                <Card className="border-none shadow-xl">
                  <CardHeader>
                    <div className="flex items-center gap-2">
                      <div className="w-8 h-8 bg-gradient-to-br from-orange-500 to-red-600 rounded-lg flex items-center justify-center">
                        <MessageSquare className="w-4 h-4 text-white" />
                      </div>
                      <CardTitle className="text-lg">Visual Q&A</CardTitle>
                    </div>
                  </CardHeader>
                  <CardContent className="space-y-4">
                    {image.visual_qa.map((qa, i) => (
                      <div key={i} className="border-l-4 border-purple-500 pl-4">
                        <p className="font-semibold text-gray-900 mb-1">Q: {qa.question}</p>
                        <p className="text-gray-700">A: {qa.answer}</p>
                      </div>
                    ))}
                  </CardContent>
                </Card>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
