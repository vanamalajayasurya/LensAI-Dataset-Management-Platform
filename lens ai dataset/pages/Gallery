import React, { useState } from "react";
import { base44 } from "@/api/base44Client";
import { useQuery } from "@tanstack/react-query";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Card } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Camera, Search, Grid3x3, Sparkles } from "lucide-react";
import { Link } from "react-router-dom";
import { createPageUrl } from "@/utils";
import { format } from "date-fns";

import ImageCard from "../components/gallery/ImageCard";
import EmptyState from "../components/gallery/EmptyState";

export default function GalleryPage() {
  const [searchQuery, setSearchQuery] = useState("");

  const { data: images, isLoading } = useQuery({
    queryKey: ['images'],
    queryFn: () => base44.entities.Image.list("-created_date"),
    initialData: [],
  });

  const filteredImages = images.filter(image => {
    if (!searchQuery) return true;
    const query = searchQuery.toLowerCase();
    return (
      image.caption?.toLowerCase().includes(query) ||
      image.ocr_text?.toLowerCase().includes(query) ||
      image.tags?.some(tag => tag.toLowerCase().includes(query)) ||
      image.objects_detected?.some(obj => obj.toLowerCase().includes(query))
    );
  });

  return (
    <div className="min-h-screen p-4 md:p-8">
      <div className="max-w-7xl mx-auto">
        <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
          <div>
            <div className="flex items-center gap-3 mb-2">
              <div className="w-10 h-10 bg-gradient-to-br from-purple-500 to-blue-600 rounded-xl flex items-center justify-center">
                <Grid3x3 className="w-5 h-5 text-white" />
              </div>
              <h1 className="text-3xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
                Your Gallery
              </h1>
            </div>
            <p className="text-gray-600">
              {images.length} {images.length === 1 ? 'image' : 'images'} analyzed
            </p>
          </div>
          <Link to={createPageUrl("Camera")}>
            <Button className="bg-gradient-to-r from-purple-500 to-blue-600 hover:from-purple-600 hover:to-blue-700 shadow-lg">
              <Camera className="w-4 h-4 mr-2" />
              Capture New
            </Button>
          </Link>
        </div>

        <Card className="p-4 mb-6 border-none shadow-lg bg-white/80 backdrop-blur-sm">
          <div className="relative">
            <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" />
            <Input
              placeholder="Search by description, text, tags, or objects..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="pl-10 border-purple-100 focus:border-purple-300"
            />
          </div>
        </Card>

        {filteredImages.length === 0 ? (
          <EmptyState hasImages={images.length > 0} />
        ) : (
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {filteredImages.map((image) => (
              <ImageCard key={image.id} image={image} />
            ))}
          </div>
        )}
      </div>
    </div>
  );
}